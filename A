```java
static class Task {
    public String encrypt(String s, int shift) {
        String result = "";
        for (char c : s.toCharArray()) {
            if (c >= 'A' && c <= 'Z')
                result += (char) ('A' + (c - 'A' + shift) % 26);
            else if (c >= 'a' && c <= 'z')
